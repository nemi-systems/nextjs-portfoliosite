    "audio:design": "bash scripts/blog-audio/uv-run.sh scripts/blog-audio/voice_workflow.py",
    "audio:post": "bash scripts/blog-audio/uv-run.sh scripts/blog-audio-post.py"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^5.18.0",
    "@mui/material": "^5.18.0",
    "@types/node": "22.15.21",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.4.24",
    "eslint": "8.57.0",
    "eslint-config-next": "15.4.6",
    "gray-matter": "^4.0.3",
    "katex": "^0.16.33",
    "mermaid": "^11.12.3",
    "next": "15.4.6",
    "postcss": "8.5.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.5.0",

    "remark-parse": "^10.0.1",
    "remark-rehype": "^10.1.0",
    "shiki": "^3.22.0",
    "svgo": "^4.0.0",
    "tailwindcss": "3.4.17",
    "typescript": "5.9.3",
    "unified": "^10.1.2",
    "unist-util-visit": "^5.1.0"
